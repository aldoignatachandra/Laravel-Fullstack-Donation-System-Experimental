APP_NAME="DonasiKita"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration (SQLite for local development)
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# MySQL Configuration (for production)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=donasikita
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@donasikita.id"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 Configuration (for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite Configuration
VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# MIDTRANS PAYMENT GATEWAY CONFIGURATION
# =============================================================================
# Get your credentials from: https://dashboard.midtrans.com

# Midtrans Merchant ID (found in Midtrans Dashboard > Settings > Access Keys)
MIDTRANS_MERCHANT_ID=

# Midtrans Server Key (found in Midtrans Dashboard > Settings > Access Keys)
# IMPORTANT: Keep this secret! Never commit the actual key to version control.
MIDTRANS_SERVER_KEY=

# Midtrans Client Key (found in Midtrans Dashboard > Settings > Access Keys)
MIDTRANS_CLIENT_KEY=

# Midtrans Environment (set to true for production)
MIDTRANS_IS_PRODUCTION=false

# Midtrans Sanitization (recommended to keep true)
MIDTRANS_IS_SANITIZED=true

# Midtrans 3D Secure (recommended to keep true for security)
MIDTRANS_IS_3DS=true

# Optional: Custom Snap Redirect Base URL
# If not set, will use default route('donation.payment')
# PAYMENT_SNAP_REDIRECT_BASE=
